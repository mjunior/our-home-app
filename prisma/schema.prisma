generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AccountType {
  CHECKING
  INVESTMENT
}

enum TransactionKind {
  INCOME
  EXPENSE
}

enum SettlementStatus {
  PAID
  UNPAID
}

enum ScheduleSourceType {
  INSTALLMENT
  RECURRING
}

model Account {
  id             String        @id @default(cuid())
  householdId    String
  name           String
  type           AccountType
  openingBalance Decimal
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  transactions   Transaction[]
  installmentPlans InstallmentPlan[]
  recurringRules RecurringRule[]
  scheduledInstances ScheduledInstance[]

  @@unique([householdId, name])
}

model CreditCard {
  id           String        @id @default(cuid())
  householdId  String
  name         String
  closeDay     Int
  dueDay       Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  installmentPlans InstallmentPlan[]
  recurringRules RecurringRule[]
  scheduledInstances ScheduledInstance[]

  @@unique([householdId, name])
}

model Category {
  id          String        @id @default(cuid())
  householdId String
  name        String
  normalized  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  transactions Transaction[]
  installmentPlans InstallmentPlan[]
  recurringRules RecurringRule[]
  scheduledInstances ScheduledInstance[]

  @@unique([householdId, normalized])
}

model Transaction {
  id           String      @id @default(cuid())
  householdId  String
  kind         TransactionKind
  description  String
  amount       Decimal
  occurredAt   DateTime
  invoiceMonthKey String?
  invoiceDueDate  DateTime?
  settlementStatus SettlementStatus?
  accountId    String?
  creditCardId String?
  categoryId   String
  transferGroupId String?

  account      Account?    @relation(fields: [accountId], references: [id])
  creditCard   CreditCard? @relation(fields: [creditCardId], references: [id])
  category     Category    @relation(fields: [categoryId], references: [id])

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([householdId, occurredAt])
  @@index([householdId, transferGroupId])
}

model InstallmentPlan {
  id                String   @id @default(cuid())
  householdId       String
  description       String
  totalAmount       Decimal
  installmentsCount Int
  startMonth        String
  categoryId        String
  accountId         String?
  creditCardId      String?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  category   Category   @relation(fields: [categoryId], references: [id])
  account    Account?   @relation(fields: [accountId], references: [id])
  creditCard CreditCard? @relation(fields: [creditCardId], references: [id])
}

model RecurringRule {
  id               String   @id @default(cuid())
  householdId      String
  kind             TransactionKind
  description      String
  amount           Decimal
  startMonth       String
  categoryId       String
  accountId        String?
  creditCardId     String?
  active           Boolean  @default(true)
  revisionOfRuleId String?
  createdAt        DateTime @default(now())

  category   Category    @relation(fields: [categoryId], references: [id])
  account    Account?    @relation(fields: [accountId], references: [id])
  creditCard CreditCard? @relation(fields: [creditCardId], references: [id])
}

model ScheduledInstance {
  id           String   @id @default(cuid())
  householdId  String
  sourceType   ScheduleSourceType
  sourceId     String
  sequence     Int
  monthKey     String
  occurredAt   DateTime
  kind         TransactionKind
  description  String
  amount       Decimal
  categoryId   String
  accountId    String?
  creditCardId String?
  instanceKey  String   @unique
  locked       Boolean  @default(false)

  category   Category    @relation(fields: [categoryId], references: [id])
  account    Account?    @relation(fields: [accountId], references: [id])
  creditCard CreditCard? @relation(fields: [creditCardId], references: [id])

  @@index([householdId, monthKey])
}

model Household {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  householdId  String
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([householdId])
}
